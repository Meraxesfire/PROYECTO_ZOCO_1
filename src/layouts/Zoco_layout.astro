---
interface Props {
  title: string;
}

const { title } = Astro.props;

import '../styles/global.css'; // Importa el archivo CSS global para que los estilos se apliquen a toda la página
---


<!doctype html>
<html lang="en">
	<head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="icon" type="image/png" href="/favicon.png" />
        <title>{title}</title> <!--Usamos el título pasado como prop(cocepto similar a una variable declarada previamente en el frontmatter) -->
	</head>
	<body>
		<slot />
	</body>
</html> 