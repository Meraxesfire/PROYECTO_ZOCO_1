---
//Definición de datos del componente:
interface Props{
    titulo:string,
    imagen:string,
}

const {titulo, imagen} = Astro.props;
---

<div class="GafaCard">
    <img src={imagen} alt={titulo} class="GafaImagen"/>
    <div class="GafaInfo">
        <h2 class="GafaTitulo">{titulo}</h2>
    </div>
</div>

<style>
    .GafaCard {
        border: none;
        background-color: white;
        overflow: hidden;
        width: min(20rem, 100%);
        height: 25rem;
        display: flex;
        flex-direction: column;
        transition: transform 0.3s ease;
        box-shadow: 0px 0px 10px 0px rgba(0, 0, 0, 0.1); /* Sombra sutil */
    }

    .GafaTitulo {
        font-size: clamp(0.85rem, 2.5vw, 1rem);
        text-align: center;
        margin: 0.5rem 0;
        font-family:'HKNova', sans-serif;
    }

    .GafaCard:hover {
        transform: scale(1.05);
    }
    .GafaCard img {
        width: 100%;
        height: auto;
        aspect-ratio: 1 / 1;
        object-fit: cover;
        display: block;
    }

    @media screen and (max-width: 768px) {
        .GafaCard {
            width: 100%;
            height: auto;
        }

        .GafaCard img {
            aspect-ratio: 1 / 1;
        }
    }
</style>